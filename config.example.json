{
  "public_base_url": "http://127.0.0.1:18989",
  "trust_forwarded_headers": false,
  "tvbox": {
    "site_key": "openlist_tvbox",
    "site_name": "OpenList",
    "language": "en",
    "timeout": 15,
    "searchable": 1,
    "quick_search": 0,
    "changeable": 0
  },
  "backends": [
    {
      "id": "main",
      "type": "openlist_v4",
      "server": "https://openlist.example.com",
      "auth_type": "api_key",
      "api_key": "replace-with-server-side-api-key"
    },
    {
      "id": "dav",
      "type": "webdav",
      "server": "https://dav.example.com/dav",
      "auth_type": "password",
      "user": "demo",
      "password": "replace-with-webdav-password"
    }
  ],
  "subs": [
    {
      "id": "all",
      "path": "/sub",
      "site_key": "openlist_tvbox",
      "site_name": "OpenList",
      "tvbox": {
        "language": "en"
      },
      "lives": [
        {
          "name": "Live",
          "type": 0,
          "url": "https://example.com/iptv.m3u"
        }
      ],
      "mounts": [
        {
          "id": "webdav_movies",
          "name": "WebDAV Movies",
          "backend": "dav",
          "path": "/Movies",
          "search": false,
          "refresh": false,
          "hidden": false
        },
        {
          "id": "movies",
          "name": "Movies",
          "backend": "main",
          "path": "/Movies",
          "params": {
            "/Private": "replace-with-directory-password"
          },
          "play_headers": {
            "User-Agent": "Mozilla/5.0",
            "Referer": "https://example.com/"
          },
          "search": true,
          "refresh": false,
          "hidden": false
        }
      ]
    }
  ]
}
